---
import { SOURCES, type FeedItem } from "@/lib/feed";

interface Props {
  items: FeedItem[];
}
const { items } = Astro.props;

const counts: Record<string, number> = { all: items.length };
for (const s of SOURCES) counts[s.key] = items.filter((i) => i.source === s.key).length;

const chips = [
  { key: "all", label: "すべて", badgeClass: "" },
  ...SOURCES.map((s) => ({ key: s.key, label: s.label, badgeClass: s.badgeClass })),
];
---

<div
  id="source-filter"
  class="sticky-surface sticky top-[var(--header-h)] z-10 -mx-4 mb-4 flex flex-wrap gap-2 border-b border-[var(--color-border)] px-4 py-3 sm:-mx-6 sm:px-6"
>
  {
    chips.map((c) => (
      <button
        type="button"
        data-filter={c.key}
        class="filter-chip inline-flex items-center gap-1.5 rounded-full border border-[var(--color-border)] bg-[var(--color-card)] px-3 py-1.5 text-[12.5px] font-medium text-[var(--color-text-muted)] transition-colors hover:border-[var(--color-border-strong)] hover:text-[var(--color-text)] aria-[pressed=true]:border-[var(--color-accent)] aria-[pressed=true]:bg-[var(--color-accent-glow)] aria-[pressed=true]:text-[var(--color-accent-bright)]"
        aria-pressed={c.key === "all" ? "true" : "false"}
      >
        {c.label}
        <span class="font-mono text-[10.5px] tabular-nums text-[var(--color-text-subtle)]">{counts[c.key]}</span>
      </button>
    ))
  }

  <!-- 表示言語の一括トグル（日本語 / 原文）。右端に寄せる -->
  <div class="ml-auto flex items-center gap-1.5">
    <span class="font-mono text-[11px] text-[var(--color-text-subtle)]">表示</span>
    <div class="flex items-center gap-1 rounded-full border border-[var(--color-border)] bg-[var(--color-card)] p-0.5">
      <button
        type="button"
        data-lang="ja"
        class="lang-toggle rounded-full px-2.5 py-1 text-[12px] font-medium text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-text)] aria-[pressed=true]:bg-[var(--color-accent-glow)] aria-[pressed=true]:text-[var(--color-accent-bright)]"
        aria-pressed="true"
      >
        日本語
      </button>
      <button
        type="button"
        data-lang="orig"
        class="lang-toggle rounded-full px-2.5 py-1 text-[12px] font-medium text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-text)] aria-[pressed=true]:bg-[var(--color-accent-glow)] aria-[pressed=true]:text-[var(--color-accent-bright)]"
        aria-pressed="false"
      >
        原文
      </button>
    </div>
  </div>
</div>

<script>
  const filterBar = document.getElementById("source-filter");
  const chips = Array.from(document.querySelectorAll<HTMLButtonElement>(".filter-chip"));
  // タイムレール行（時刻＋カードを包むラッパ）単位で出し分ける
  const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-feed-item]"));
  const daySections = Array.from(document.querySelectorAll<HTMLElement>("[data-day-section]"));

  // ===== sticky オフセットを実測して CSS 変数に反映（手書きマジックナンバー廃止）=====
  // --header-h = ヘッダー高さ（フィルタの top）、--stack-h = ヘッダー＋フィルタ（日付見出しの top）。
  // フィルタは flex-wrap で行数が変わるため、リサイズ／フォント読込で追従させる。
  const header = document.getElementById("app-header");
  function measureSticky() {
    const root = document.documentElement.style;
    if (header) root.setProperty("--header-h", `${header.offsetHeight}px`);
    if (header && filterBar)
      root.setProperty("--stack-h", `${header.offsetHeight + filterBar.offsetHeight}px`);
  }
  measureSticky();
  const stickyObserver = new ResizeObserver(measureSticky);
  if (header) stickyObserver.observe(header);
  if (filterBar) stickyObserver.observe(filterBar);
  window.addEventListener("resize", measureSticky);
  document.fonts?.ready.then(measureSticky);

  function applyFilter(filter: string) {
    for (const card of cards) {
      const match = filter === "all" || card.dataset.source === filter;
      card.classList.toggle("is-hidden", !match);
    }
    // 中身が全部隠れた日付セクションは見出しごと隠す
    for (const section of daySections) {
      const visible = section.querySelectorAll(
        "[data-feed-item]:not(.is-hidden)",
      ).length;
      section.classList.toggle("is-hidden", visible === 0);
    }
    for (const chip of chips) {
      chip.setAttribute("aria-pressed", chip.dataset.filter === filter ? "true" : "false");
    }
  }

  filterBar?.addEventListener("click", (e) => {
    const chip = (e.target as HTMLElement).closest<HTMLButtonElement>(".filter-chip");
    if (!chip?.dataset.filter) return;
    applyFilter(chip.dataset.filter);
  });

  // ===== 表示言語トグル（日本語 / 原文）。:root.show-orig を切り替える =====
  const langButtons = Array.from(document.querySelectorAll<HTMLButtonElement>(".lang-toggle"));
  const LANG_KEY = "todayai:lang";

  function applyLang(lang: string) {
    document.documentElement.classList.toggle("show-orig", lang === "orig");
    for (const b of langButtons) {
      b.setAttribute("aria-pressed", b.dataset.lang === lang ? "true" : "false");
    }
  }

  // 保存済みの選択を復元（既定: 日本語）
  applyLang(localStorage.getItem(LANG_KEY) === "orig" ? "orig" : "ja");

  for (const b of langButtons) {
    b.addEventListener("click", () => {
      const lang = b.dataset.lang === "orig" ? "orig" : "ja";
      localStorage.setItem(LANG_KEY, lang);
      applyLang(lang);
    });
  }
</script>
