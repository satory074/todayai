---
import type { FeedItem } from "@/lib/feed";
import { SOURCES } from "@/lib/feed";
import TweetCard from "./TweetCard.astro";
import BilingualText from "./BilingualText.astro";

interface Props {
  item: FeedItem;
}

const { item } = Astro.props;
const meta = SOURCES.find((s) => s.key === item.source)!;
// 画像の有無でレイアウトを分岐（ハイブリッド）。X は専用カード。
const variant = item.source === "x" ? "tweet" : item.thumbnail ? "hero" : "compact";
---

{
  variant === "tweet" ? (
    <TweetCard item={item} />
  ) : variant === "hero" ? (
    <article
      data-source={item.source}
      class="group relative flex flex-col overflow-hidden rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] shadow-[0_1px_2px_rgba(20,22,27,0.04)] transition-all duration-[var(--duration-base)] hover:border-[var(--color-border-strong)] hover:shadow-[0_6px_20px_rgba(20,22,27,0.09)] sm:flex-row"
    >
      <a
        href={item.url}
        target="_blank"
        rel="noopener noreferrer"
        class="absolute inset-0 z-20"
        aria-label={item.title}
      />

      <div class="relative z-10 aspect-video w-full overflow-hidden bg-[var(--color-surface)] sm:aspect-auto sm:w-[14rem] sm:shrink-0 sm:self-stretch">
        <img
          src={item.thumbnail}
          alt=""
          loading="lazy"
          class="h-full w-full object-cover transition-transform duration-500 ease-[var(--ease-out-soft)] group-hover:scale-[1.03]"
          onerror="this.parentElement.style.display='none'"
        />
      </div>

      <div class="relative z-10 min-w-0 p-4 sm:flex-1">
        <div class="mb-2 flex items-center gap-2">
          <span
            class={`inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-semibold tracking-wide ${meta.badgeClass}`}
          >
            {meta.label}
          </span>
          {item.author && (
            <span class="truncate font-mono text-[11px] text-[var(--color-text-subtle)]">
              {item.author}
            </span>
          )}
        </div>

        <h2 class="font-display text-[17px] font-semibold leading-snug text-[var(--color-text)] transition-colors group-hover:text-[var(--color-accent-bright)]">
          <BilingualText orig={item.title} ja={item.titleJa} />
        </h2>

        {item.summary && (
          <p class="mt-2 line-clamp-[5] text-[15px] leading-relaxed text-[var(--color-text-muted)]">
            <BilingualText orig={item.summary} ja={item.summaryJa} />
          </p>
        )}

        {item.bookmarkCount !== undefined && (
          <div class="mt-3 inline-flex items-center gap-1 rounded-md bg-[var(--color-hatena-bg)] px-2 py-0.5 text-[11px] font-medium text-[var(--color-hatena)]">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-3 w-3">
              <path d="M6 2a2 2 0 0 0-2 2v18l8-5.5L20 22V4a2 2 0 0 0-2-2H6z" />
            </svg>
            {item.bookmarkCount} users
          </div>
        )}
      </div>
    </article>
  ) : (
    <article
      data-source={item.source}
      class="group relative rounded-lg border border-[var(--color-border)] bg-[var(--color-card)] px-3.5 py-2.5 transition-colors duration-[var(--duration-base)] hover:border-[var(--color-border-strong)] hover:bg-[var(--color-card-hover)]"
    >
      <a
        href={item.url}
        target="_blank"
        rel="noopener noreferrer"
        class="absolute inset-0 z-20 rounded-lg"
        aria-label={item.title}
      />

      <div class="relative z-10 flex items-start gap-2.5">
        <span
          class={`mt-px inline-flex shrink-0 items-center rounded-full px-2 py-0.5 text-[10.5px] font-semibold tracking-wide ${meta.badgeClass}`}
        >
          {meta.label}
        </span>
        <div class="min-w-0 flex-1">
          <h2 class="line-clamp-2 text-[14px] font-medium leading-snug text-[var(--color-text)] transition-colors group-hover:text-[var(--color-accent-bright)]">
            <BilingualText orig={item.title} ja={item.titleJa} />
          </h2>
          {item.summary && (
            <p class="mt-0.5 line-clamp-2 text-[13px] leading-relaxed text-[var(--color-text-muted)]">
              <BilingualText orig={item.summary} ja={item.summaryJa} />
            </p>
          )}
          {(item.author || item.bookmarkCount !== undefined) && (
            <div class="mt-1 flex items-center gap-2 font-mono text-[11px] text-[var(--color-text-subtle)]">
              {item.author && <span class="truncate">{item.author}</span>}
              {item.bookmarkCount !== undefined && (
                <span class="shrink-0">★ {item.bookmarkCount}</span>
              )}
            </div>
          )}
        </div>
      </div>
    </article>
  )
}
