---
import Layout from "@/components/Layout.astro";
import FeedCard from "@/components/FeedCard.astro";
import SourceFilter from "@/components/SourceFilter.astro";
import {
  dayKey,
  dayLabel,
  relativeTime,
  timeOfDay,
  type FeedData,
  type FeedItem,
} from "@/lib/feed";
import { readFeed } from "@/lib/feedStore";

// ビルド時にデータを取得。GCS_BUCKET 設定時は GCS の public URL、未設定ならローカル feed.json。
// 集約と同じ run のビルドが書き込み直後の最新を読むよう GITHUB_RUN_ID でキャッシュバスト。
const feed = await readFeed<FeedData>(
  { updatedAt: new Date(0).toISOString(), items: [] },
  { bust: process.env.GITHUB_RUN_ID },
);
const items = [...feed.items].sort(
  (a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime(),
);

// 日付ごとにグループ化（表示順を維持）
const groups: { key: string; label: string; items: FeedItem[] }[] = [];
for (const item of items) {
  const key = dayKey(item.publishedAt);
  let group = groups.find((g) => g.key === key);
  if (!group) {
    group = { key, label: dayLabel(key), items: [] };
    groups.push(group);
  }
  group.items.push(item);
}

const updatedRel = feed.updatedAt ? relativeTime(feed.updatedAt) : "";
---

<Layout>
  <section class="pb-1 pt-4">
    <h1 class="font-display text-[26px] font-bold tracking-tight text-[var(--color-text)]">
      AI情報フィード
    </h1>
    <p class="mt-1.5 text-[13px] text-[var(--color-text-muted)]">
      X・Zenn・Qiita・はてブ・Workspace・LayerX から自動集約。
      {updatedRel && <span class="font-mono text-[var(--color-text-subtle)]">更新 {updatedRel}</span>}
    </p>
  </section>

  <SourceFilter items={items} />

  {
    items.length === 0 ? (
      <div class="rounded-xl border border-dashed border-[var(--color-border)] bg-[var(--color-card)] p-10 text-center text-[var(--color-text-muted)]">
        <p>まだアイテムがありません。</p>
        <p class="mt-1 text-[12px] text-[var(--color-text-subtle)]">
          <code>npm run aggregate</code> を実行するとフィードが取り込まれます。
        </p>
      </div>
    ) : (
      <div class="space-y-8">
        {groups.map((group) => (
          <section data-day-section>
            <h2 class="sticky top-[var(--stack-h)] z-[5] mb-3 inline-flex items-center rounded-md bg-[var(--color-card)] px-2.5 py-1 font-mono text-[12px] font-semibold tracking-wide text-[var(--color-text-muted)] shadow-[0_1px_2px_rgba(20,22,27,0.05)] ring-1 ring-[var(--color-border)]">
              {group.label}
            </h2>
            <div class="space-y-3">
              {group.items.map((item) => (
                <div
                  data-feed-item
                  data-source={item.source}
                  class="grid grid-cols-[2.75rem_1fr] gap-2.5 sm:grid-cols-[3.5rem_1fr] sm:gap-3"
                >
                  <time class="pt-1 text-right font-mono text-[12px] tabular-nums text-[var(--color-text-subtle)]">
                    {timeOfDay(item.publishedAt)}
                  </time>
                  <div class="border-l border-[var(--color-border)] pl-2.5 sm:pl-3">
                    <FeedCard item={item} />
                  </div>
                </div>
              ))}
            </div>
          </section>
        ))}
      </div>
    )
  }
</Layout>
